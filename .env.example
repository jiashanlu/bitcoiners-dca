# bitcoiners-dca — environment variable secrets
#
# Copy this file to .env (which is gitignored) and fill in your real API keys.
# Only set credentials for exchanges you've ENABLED in config.yaml — others are ignored.

# === OKX UAE ===
# Generate at: okx.com → Account → API → Create API Key
# Permissions needed: Read, Trade. Withdrawal optional (only if you want auto-withdraw).
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=

# === BINANCE UAE ===
# Generate at: binance.ae → API Management
BINANCE_API_KEY=
BINANCE_API_SECRET=

# === BITOASIS ===
# Bearer-token auth (single token, no separate secret).
# Generate at: bitoasis.net → Settings → API Token Management → + Add Token
# Permissions: enable Trade (+ Withdraw only if you use auto-withdraw).
# Account must be Tier 1 verified at minimum.
BITOASIS_API_TOKEN=

# === TELEGRAM NOTIFICATIONS ===
# 1. Create bot via @BotFather on Telegram → get bot token
# 2. Find your chat ID: message @userinfobot, copy the ID
# 3. Send a /start message to your new bot first
TG_BOT_TOKEN=
# Note: chat_id goes in config.yaml, not here.

# === DRY-RUN OVERRIDE ===
# Set to "true" to simulate ALL trades without placing real orders.
# Useful for first-run testing.
BITCOINERS_DCA_DRY_RUN=false
